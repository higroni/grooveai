  "assertions": [
    {
      "assertion_id": "542d57cc-5d10-4165-981c-a5670152104d",
      "text": "Prava, obaveze i odgovornosti iz radnog odnosa, odnosno po osnovu rada, uređuju se ovim zakonom i posebnim zakonom, u skladu sa ratifikovanim međunarodnim konvencijama.",
      "confidence": 0.5,
      "sentence_index": 0,
      "start_char": 0,
      "end_char": 169
    },
    {
      "assertion_id": "4c03f908-167b-4483-b96b-fe21a3e75034",
      "text": "Prava, obaveze i odgovornosti iz radnog odnosa uređuju se i kolektivnim ugovorom i ugovorom o radu, a pravilnikom o radu, odnosno ugovorom o radu – samo kada je to ovim zakonom određeno.",
      "confidence": 0.5,
      "sentence_index": 1,
      "start_char": 169,
      "end_char": 355
    },
    {
      "assertion_id": "00e32e39-ed9d-4e9c-8d2c-facf8a08715b",
      "text": "Odredbe ovog zakona primenjuju se na zaposlene koji rade na teritoriji Republike Srbije, kod domaćeg ili stranog pravnog, odnosno fizičkog lica (u daljem tekstu: poslodavac), kao i na zaposlene koji su upućeni na rad u inostranstvo od strane poslodavca ako zakonom nije drukčije određeno.",
      "confidence": 0.5,
      "sentence_index": 0,
      "start_char": 0,
      "end_char": 289
    },
    {
      "assertion_id": "b84e1217-f147-4ab8-a907-34930c73d5d4",
      "text": "Odredbe ovog zakona primenjuju se i na zaposlene u državnim organima, organima teritorijalne autonomije i lokalne samouprave i javnim službama, ako zakonom nije drukčije određeno.",
      "confidence": 0.5,
      "sentence_index": 1,
      "start_char": 289,
      "end_char": 469
    },
    {
      "assertion_id": "ca678894-a495-458c-b5ce-8a83b0b509a0",
      "text": "Odredbe ovog zakona primenjuju se i na zaposlene kod poslodavaca u oblasti saobraćaja, ako posebnim propisom nije drukčije određeno.",
      "confidence": 0.5,
      "sentence_index": 2,
      "start_char": 469,
      "end_char": 602
    },
    {
      "assertion_id": "8fe6aa00-f12f-4ec5-adf3-b082511f3b82",
      "text": "Odredbe ovog zakona primenjuju se na zaposlene strane državljane i lica bez državljanstva koji rade kod poslodavca na teritoriji Republike Srbije, ako zakonom nije drukčije određeno.",
      "confidence": 0.5,
      "sentence_index": 3,
      "start_char": 602,
      "end_char": 785
    },
    {
      "assertion_id": "e61057d9-a6b7-45f3-bfd0-96f16f3ef715",
      "text": "Kolektivnim ugovorom kod poslodavca, u skladu sa zakonom, uređuju se prava, obaveze i odgovornosti iz radnog odnosa i međusobni odnosi učesnika kolektivnog ugovora.",
      "confidence": 0.5,
      "sentence_index": 0,
      "start_char": 0,
      "end_char": 165
    },
    {
      "assertion_id": "2b78afe1-613f-4b5f-8177-c4a644a1004b",
      "text": "Pravilnikom o radu, odnosno ugovorom o radu, u skladu sa zakonom, uređuju se prava, obaveze i odgovornosti iz radnog odnosa: 1) ako kod poslodavca nije osnovan sindikat ili nijedan sindikat ne ispunjava uslove reprezentativnosti ili nije zaključen sporazum o udruživanju u skladu sa ovim zakonom; 2) ako nijedan učesnik kolektivnog ugovora ne pokrene inicijativu za početak pregovora radi zaključivanja kolektivnog ugovora; 3) ako učesnici kolektivnog ugovora ne postignu saglasnost za zaključivanje kolektivnog ugovora u roku od 60 dana od dana započinjanja pregovora; 4) ako sindikat, u roku od 15 dana od dana dostavljanja poziva za početak pregovora za zaključivanje kolektivnog ugovora, ne prihvati inicijativu poslodavca.",
      "confidence": 0.5,
      "sentence_index": 1,
      "start_char": 165,
      "end_char": 893
    },
    {
      "assertion_id": "c6722a6c-8dce-4cb6-b7e1-a2c9cca17da7",
      "text": "tačka 3) ovog člana učesnici kolektivnog ugovora dužni su da nastave pregovore u dobroj veri.",
      "confidence": 0.5,
      "sentence_index": 3,
      "start_char": 915,
      "end_char": 1009
    },
    {
      "assertion_id": "c3ee605c-2f34-48ed-a6f1-c124809290fb",
      "text": "tačka 3) ovog člana, poslodavac je dužan da pravilnik o radu dostavi reprezentativnom sindikatu u roku od sedam dana od dana njegovog stupanja na snagu.",
      "confidence": 0.7999999999999999,
      "sentence_index": 5,
      "start_char": 1031,
      "end_char": 1184
    },
    {
      "assertion_id": "2befa2c7-6581-4ebd-864a-39b07d98d4fd",
      "text": "Poslodavac koji ne prihvati inicijativu reprezentativnog sindikata za pristupanje pregovorima za zaključenje kolektivnog ugovora, ne može pravilnikom o radu da uredi prava i obaveze iz radnog odnosa.",
      "confidence": 1.0,
      "sentence_index": 6,
      "start_char": 1184,
      "end_char": 1384
    },
    {
      "assertion_id": "cc414e4f-02f9-4907-a003-e4d9b5252dc5",
      "text": "Pravilnik o radu donosi nadležni organ kod poslodavca, utvrđen zakonom, odnosno osnivačkim ili drugim opštim aktom poslodavca, a kod poslodavca koji nema svojstvo pravnog lica donosi ovlašćeno lice u skladu sa zakonom.",
      "confidence": 0.5,
      "sentence_index": 7,
      "start_char": 1384,
      "end_char": 1603
    },
    {
      "assertion_id": "a2c7ac99-95e6-4b47-9912-2dc13dbcc915",
      "text": "Pravilnik o radu javnog preduzeća i društva kapitala čiji je osnivač Republika, autonomna pokrajina ili jedinica lokalne samouprave (u daljem tekstu: javno preduzeće) i društva kapitala čiji je osnivač javno preduzeće, donosi se uz prethodnu saglasnost osnivača.",
      "confidence": 0.5,
      "sentence_index": 8,
      "start_char": 1603,
      "end_char": 1866
    },
    {
      "assertion_id": "f342f526-24ac-43d8-8219-379f5fde934f",
      "text": "Pravilnik o radu prestaje da važi danom stupanja na snagu kolektivnog ugovora iz stava 1.",
      "confidence": 0.5,
      "sentence_index": 9,
      "start_char": 1866,
      "end_char": 1956
    },
    {
      "assertion_id": "ac833d67-6eaf-4e14-ac6d-c9af22a164ca",
      "text": "Opšti i poseban kolektivni ugovor moraju biti u saglasnosti sa zakonom.",
      "confidence": 0.5,
      "sentence_index": 0,
      "start_char": 0,
      "end_char": 72
    },
    {
      "assertion_id": "f942cc7b-a29e-4ac4-8b21-d5f4b7960c03",
      "text": "Kolektivni ugovor kod poslodavca, pravilnik o radu i ugovor o radu moraju biti u saglasnosti sa zakonom, a kod poslodavca iz čl.",
      "confidence": 0.5,
      "sentence_index": 1,
      "start_char": 72,
      "end_char": 201
    },
    {
      "assertion_id": "7ba5d1f1-312e-4276-abf9-3338b0e5c43c",
      "text": "ovog zakona – i sa opštim i posebnim kolektivnim ugovorom.",
      "confidence": 0.5,
      "sentence_index": 4,
      "start_char": 213,
      "end_char": 271
    },
    {
      "assertion_id": "10ab07b3-9ba6-4135-bd95-ab4b3b47c8b1",
      "text": "Zaposleni, u smislu ovog zakona, jeste fizičko lice koje je u radnom odnosu kod poslodavca.",
      "confidence": 0.5,
      "sentence_index": 0,
      "start_char": 0,
      "end_char": 92
    },
    {
      "assertion_id": "aa3f69e9-c43b-4a63-9a7e-099ff56aad6b",
      "text": "Poslodavac, u smislu ovog zakona, jeste domaće, odnosno strano pravno ili fizičko lice koje zapošljava, odnosno radno angažuje, jedno ili više lica.",
      "confidence": 0.5,
      "sentence_index": 1,
      "start_char": 92,
      "end_char": 240
    }
  ],
